process {
  withName:illumination   {
    time   = '6h'
    memory = '64G'
  }
  withName:coreograph     {
    time   = '12h'
    memory = '128G'
  }
  withName:ashlar         {
    time   = '6h'
    memory = '64G'
  }
  withName:s3seg          {
    cpus   = 6
    time   = '12h'
    memory = '230G'
  }
  withName:mcquant        {
    time   = '12h'
    memory = '128G'
  }
  // Use the fully-qualified name so this matches minerva.config's rule
  // and the higher memory/time values win when profiles are combined.
  withName: 'segmentation:worker' {
    cpus   = 8
    time   = '24h'
    memory = '230G'
  }
}
