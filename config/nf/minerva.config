// Minerva HPC config — Mount Sinai Icahn School of Medicine
// Scheduler : IBM Spectrum LSF
// Containers: Apptainer (successor to Singularity)
// User      : giocrm
// Project   : vascbrain / OrionCadasil

includeConfig 'singularity.config'

process {
  executor       = 'lsf'
  queue          = 'premium'
  clusterOptions = '-P acc_vascbrain'   // Minerva allocation — verify with: bacct

  // Default resources for any process not explicitly named below
  cpus   = 4
  time   = '12h'
  memory = '64G'

  withName: illumination {
    time   = '6h'
    memory = '64G'
  }

  withName: ashlar {
    time   = '6h'
    memory = '64G'
  }

  withName: coreograph {
    time   = '12h'
    memory = '128G'
  }

  // Segmentation probability map generators (unmicst, cellpose, etc.)
  withName: 'segmentation:worker' {
    cpus   = 8
    time   = '24h'
    memory = '128G'
  }

  // Watershed / cell boundary segmentation
  withName: s3seg {
    cpus   = 6
    time   = '12h'
    memory = '128G'
  }

  withName: mcquant {
    time   = '12h'
    memory = '64G'
  }

  withName: downstream {
    time   = '6h'
    memory = '32G'
  }
}
